---
import BaseLayout from "../layouts/BaseLayout.astro";
import { faqItems, meta, primaryActions } from "../data/site";
---

<BaseLayout
  title={meta.faq.title}
  description={meta.faq.description}
  path={meta.faq.path}
  bodyClass="faq-page"
>
  <main class="site-shell">
    <section class="hero">
      <p class="eyebrow">FAQ</p>
      <h1>Everything you need before turning your phone into a cleaner teleprompter setup.</h1>
      <p class="lede">
        This covers the room-code flow, second-device setup, and how the web remote fits into a
        real recording workflow.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={primaryActions.download.href}>
          {primaryActions.download.label}
        </a>
        <a class="button button-secondary" href={primaryActions.remote.href}>
          {primaryActions.remote.label}
        </a>
      </div>
    </section>

    <section class="panel">
      <div class="section-heading">
        <p class="eyebrow">Common questions</p>
        <h2>Setup, workflow, and how the remote fits into your shoot.</h2>
      </div>
      <div class="faq-list">
        {faqItems.map((item) => (
          <article>
            <h2>{item.question}</h2>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
