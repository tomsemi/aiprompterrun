---
import { faqItems } from "../data/site";
---

<section class="panel">
  <div class="section-heading">
    <p class="eyebrow">FAQ</p>
    <h2>Questions people ask before they bring a second phone into the setup.</h2>
  </div>
  <div class="faq-list">
    {faqItems.slice(0, 4).map((item) => (
      <article>
        <h3>{item.question}</h3>
        <p>{item.answer}</p>
      </article>
    ))}
  </div>
  <a class="text-link" href="/faq">Read the full FAQ</a>
</section>
