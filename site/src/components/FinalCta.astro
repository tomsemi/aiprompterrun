---
import { primaryActions } from "../data/site";
---

<section class="final-cta">
  <p class="eyebrow">Ready to try it</p>
  <h2>Start on the main device. Control it from the second one when the camera is rolling.</h2>
  <p class="lede">
    Built for creators who want teleprompter control to feel like part of the rig, not an interruption.
  </p>
  <div class="hero-actions">
    <a class="button button-primary" href={primaryActions.download.href}>
      {primaryActions.download.label}
    </a>
    <a class="button button-secondary" href={primaryActions.remote.href}>
      {primaryActions.remote.label}
    </a>
  </div>
</section>
